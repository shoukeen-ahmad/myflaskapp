pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out code...'
                // Add your checkout commands here
                git branch: 'main', url: 'https://github.com/shoukeen-ahmad/myflaskapp.git
            }
        }
    stages {
        stage('Build') {
            steps {
                echo 'Building...'
                // Add your build commands here
            }
        }
        stage('Test') {
            steps {
                echo 'Testing...'
                // Add your test commands here
            }
        }
        stage('Deploy') {
            steps {
                echo 'Deploying...'
                // Add your deploy commands here
            }
        }
        stages { 'Run Container' {
            steps {
                echo 'Running container...'
                sh 'docker run -d -p 5000:5000 my-flask-app'
                // Add your container run commands here
            }
        }
    }

    post {
        always {
            echo 'This will always run after the stages.'
        }
        success {
            echo 'This will run only if the stages were successful.'
        }
        failure {
            echo 'This will run only if the stages failed.'
        }
    }
}